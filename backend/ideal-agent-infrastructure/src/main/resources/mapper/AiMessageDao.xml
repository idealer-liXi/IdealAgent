<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.idealagent.infrastructure.persistent.dao.IAiMessageDao">
    <resultMap id="dataMap" type="com.idealagent.infrastructure.persistent.po.AiMessage">
        <id column="message_id" property="messageId"/>
        <result column="session_id" property="sessionId"/>
        <result column="message_type" property="messageType"/>
        <result column="message_role" property="messageRole"/>
        <result column="message_content" property="messageContent"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" parameterType="com.idealagent.infrastructure.persistent.po.AiMessage">
        INSERT INTO ai_message (message_id, session_id, message_type, message_role, message_content)
        VALUES (#{messageId}, #{sessionId}, #{messageType}, #{messageRole}, #{messageContent})
    </insert>

    <select id="listBySessionId" resultMap="dataMap">
        SELECT message_id, session_id, message_type, message_role, message_content, create_time
        FROM ai_message
        WHERE session_id = #{sessionId}
        ORDER BY id ASC
    </select>
</mapper>
