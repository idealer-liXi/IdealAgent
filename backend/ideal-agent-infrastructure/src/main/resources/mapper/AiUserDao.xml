<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.idealagent.infrastructure.persistent.dao.IAiUserDao">
    <resultMap id="dataMap" type="com.idealagent.infrastructure.persistent.po.AiUser">
        <id column="id" property="id"/>
        <result column="user_name" property="userName"/>
        <result column="password" property="password"/>
        <result column="user_role" property="userRole"/>
        <result column="user_avatar" property="userAvatar"/>
        <result column="user_status" property="userStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="queryByUserName" resultMap="dataMap">
        SELECT id, user_name, password, user_role, user_avatar, user_status, create_time, update_time
        FROM ai_user
        WHERE user_name = #{userName}
        LIMIT 1
    </select>

    <select id="queryById" resultMap="dataMap">
        SELECT id, user_name, password, user_role, user_avatar, user_status, create_time, update_time
        FROM ai_user
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.idealagent.infrastructure.persistent.po.AiUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_user (user_name, password, user_role, user_avatar, user_status)
        VALUES (#{userName}, #{password}, #{userRole}, #{userAvatar}, #{userStatus})
    </insert>
</mapper>
